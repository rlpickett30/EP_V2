{
    "tdoa_subsystem": {
        "minimum_tdoa_nodes": 4,
        "default_sample_rate_hz": 96000
    },

    "tdoa_dispatcher": {
        "enable_candidate_filter": true,
        "enable_debug_logging": true,
        "max_recent_avis_lite_events": 250
    },

    "tdoa_state_manager": {
        "min_tdoa_capable_nodes": 4,
        "publish_capability_changes_only": true
    },

    "tdoa_manager": {
        "debug": false,
        "debug_event_detection": false,
        "debug_event_analysis": false,
        "debug_event_solver": false,
        "debug_solver_consensus": false,
        "max_recordings_stored": 250,
        "default_sample_rate_hz": 96000,
        "solver_mode": "default",
        "minimum_solver_nodes": 4
    },

    "candidate_filter": {
        "avis_lite_match_window_seconds": 0.050,
        "min_matching_nodes": 4,
        "max_candidate_age_seconds": 2.0,
        "prefer_largest_group": true,
        "prefer_smallest_time_spread": true
    },

    "TDOA_event_detection": {
        "onset_method": "energy_threshold_onset",
        "offset_method": "energy_threshold_offset",
        "include_event_window": true,
        "minimum_event_duration_seconds": 0.0,
        "maximum_event_duration_seconds": null
    },

    "energy_threshold_onset": {
        "noise_window_seconds": 2.0,
        "onset_multiplier": 6.0,
        "min_active_seconds": 0.01,
        "minimum_detection_spacing_seconds": 0.025
    },

    "energy_threshold_offset": {
        "noise_window_seconds": 2.0,
        "offset_multiplier": 4.0,
        "min_quiet_seconds": 0.15,
        "minimum_detection_spacing_seconds": 0.025
    },

    "sign_pattern_onset": {
        "run_length": 3,
        "max_backtrack_samples": 7,
        "minimum_detection_spacing_seconds": 0.025
    },

    "sign_pattern_offset": {
        "run_length": 3,
        "max_forwardtrack_samples": 7,
        "minimum_detection_spacing_seconds": 0.025
    },

    "general_features": {
        "extract_peak_amplitude": true,
        "use_absolute_peak": true,
        "return_peak_time": true
    },

    "TDOA_event_analysis": {
        "minimum_channels_required": 4,
        "use_valid_consensus_only": true
    },

    "event_matching": {
        "alignment_feature": "onset_sample",
        "match_tolerance_samples": 2000,
        "reference_channel_mode": "first",
        "minimum_channels_required": 4
    },

    "matching_consensus": {
        "alignment_feature": "onset_sample",
        "max_spread_samples": 2000,
        "max_std_deviation_samples": 750,
        "minimum_channels_required": 4
    },

    "TDOA_event_solver": {
        "sample_rate_hz": 96000,
        "speed_of_sound_mps": 340.0,
        "minimum_channels_required": 4,
        "solver_method": "least_squares",
        "max_residual_error": 1.0
    },

    "solver_consensus": {
        "minimum_solutions_required": 1,
        "max_residual_error": 1.0,
        "prefer_lowest_residual": true,
        "max_position_spread_meters": 5.0
    },

    "microphone_positions": {
        "CH1": [0.0, 0.0, 0.0],
        "CH2": [1.0, 0.0, 0.0],
        "CH3": [0.0, 1.0, 0.0],
        "CH4": [0.0, 0.0, 1.0]
    }
}