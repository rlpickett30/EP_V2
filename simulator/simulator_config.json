{
  "simulator": {
    "node_id": "faux_node_01",
    "node_name": "Faux Node 01",
    "target": "server",
    "default_mode": "manual"
  },

  "network": {
    "server_ip": "127.0.0.1",
    "server_port": 5005
  },

  "events": {
    "AVIS_LITE": {
      "enabled": true,
      "cadence_seconds": 10,
      "payload": {
        "species_common": "American Robin",
        "species_scientific": "Turdus migratorius",
        "confidence": 0.87,
        "detection_time_utc": "AUTO",
        "recording_id": "REC_FAUX_001",
        "recording_path": "/recordings/faux_node_01/robin.wav"
      }
    },

    "TDOA_RECORDING": {
      "enabled": true,
      "cadence_seconds": 15,
      "payload": {
        "recording_id": "REC_FAUX_001",
        "recording_path": "/recordings/faux_node_01/tdoa_test.wav",
        "sample_rate_hz": 96000,
        "channels": 1,
        "duration_seconds": 5.0,
        "pps_aligned": true,
        "start_time_utc": "AUTO"
      }
    },

    "PPS_STATE": {
      "enabled": true,
      "cadence_seconds": 20,
      "payload": {
        "pps_available": true,
        "pps_locked": true,
        "last_tick_utc": "AUTO"
      }
    },

    "GPS_STATE": {
      "enabled": true,
      "cadence_seconds": 20,
      "payload": {
        "gps_available": true,
        "gps_lock": true,
        "fix_type": "RTK_FIXED",
        "satellites": 18
      }
    },

    "GPS_COORD": {
      "enabled": true,
      "cadence_seconds": 25,
      "payload": {
        "latitude": 37.2753,
        "longitude": -107.8801,
        "altitude_m": 2012.4,
        "horizontal_accuracy_m": 0.02,
        "vertical_accuracy_m": 0.04,
        "coord_time_utc": "AUTO"
      }
    },

    "ENVIRONMENTAL_DATA": {
      "enabled": true,
      "cadence_seconds": 30,
      "payload": {
        "temperature_c": 18.6,
        "humidity_percent": 41.2,
        "pressure_hpa": 802.4,
        "sample_time_utc": "AUTO"
      }
    },

    "SHT45_STATE": {
      "enabled": true,
      "cadence_seconds": 30,
      "payload": {
        "sensor": "SHT45",
        "available": true,
        "healthy": true,
        "last_sample_utc": "AUTO"
      }
    },

    "BMP390_STATE": {
      "enabled": true,
      "cadence_seconds": 30,
      "payload": {
        "sensor": "BMP390",
        "available": true,
        "healthy": true,
        "last_sample_utc": "AUTO"
      }
    }
  }
}